---
import type { Locale } from '~/data/types';
import { profile } from '~/data';
import { t } from '~/i18n/ui';
import Section from './Section.astro';

type Props = { locale: Locale };
const { locale } = Astro.props;
const s = t(locale);
---

<Section id="about" eyebrow="00" title={s.sections.about} class="!py-14 md:!py-16">
  <p class="max-w-3xl text-lg md:text-xl leading-relaxed text-[var(--fg)]/90 font-serif">
    {profile.bio[locale]}
  </p>
</Section>

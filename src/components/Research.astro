---
import type { Locale } from '~/data/types';
import { profile } from '~/data';
import { researchAgenda } from '~/data/research';
import { t } from '~/i18n/ui';
import Section from './Section.astro';

type Props = { locale: Locale };
const { locale } = Astro.props;
const s = t(locale);
---

<Section id="research" eyebrow="01" title={s.sections.research}>
  <div class="grid gap-5 md:grid-cols-3 mb-12">
    {
      researchAgenda.map((item) => (
        <article class="surface p-6 flex flex-col">
          <span class="self-start text-[10px] font-mono uppercase tracking-wider px-2 py-0.5 rounded-full border hairline text-[var(--accent)] mb-4">
            {item.tag[locale]}
          </span>
          <h3 class="font-serif text-lg leading-snug mb-2">{item.title[locale]}</h3>
          <p class="text-sm text-muted leading-relaxed">{item.description[locale]}</p>
        </article>
      ))
    }
  </div>

  <div class="grid gap-10 md:grid-cols-2">
    <div>
      <h3 class="font-serif text-xl mb-4">{s.sections.keywords}</h3>
      <ul class="flex flex-wrap gap-2">
        {
          profile.keywords.map((k) => (
            <li class="px-3 py-1.5 rounded-full surface text-sm">{k[locale]}</li>
          ))
        }
      </ul>
    </div>
    <div>
      <h3 class="font-serif text-xl mb-4">{s.sections.fields}</h3>
      <ul class="space-y-2">
        {
          profile.fields.map((f) => (
            <li class="flex items-start gap-3 text-sm">
              <span class="mt-1.5 inline-block w-1.5 h-1.5 rounded-full bg-[var(--accent)]" aria-hidden="true" />
              <span>{f[locale]}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</Section>

---
type Props = {
  id: string;
  eyebrow?: string;
  title: string;
  description?: string;
  count?: number;
  countLabel?: string;
  class?: string;
};
const { id, eyebrow, title, description, count, countLabel, class: extra = '' } = Astro.props;
---

<section id={id} class={`scroll-mt-24 py-20 md:py-24 ${extra}`}>
  <div class="container-page">
    <header class="mb-10 md:mb-14 max-w-3xl">
      {
        eyebrow && (
          <p class="text-xs font-mono uppercase tracking-[0.18em] text-[var(--accent)] mb-3">
            {eyebrow}
          </p>
        )
      }
      <h2 class="font-serif text-3xl md:text-4xl font-semibold tracking-tight leading-tight">
        {title}
        {
          typeof count === 'number' && (
            <span class="ml-3 text-base font-sans font-normal text-muted align-middle">
              {count}
              {countLabel ? ` ${countLabel}` : ''}
            </span>
          )
        }
      </h2>
      {description && <p class="mt-3 text-muted leading-relaxed">{description}</p>}
    </header>
    <slot />
  </div>
</section>

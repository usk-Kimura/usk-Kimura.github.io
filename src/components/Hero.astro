---
import type { Locale } from '~/data/types';
import { profile, publications } from '~/data';
import { t } from '~/i18n/ui';
import Portrait from './Portrait.astro';

type Props = { locale: Locale };
const { locale } = Astro.props;
const s = t(locale);

const recent = [...publications]
  .filter((p) => p.flags?.includes('first-author') || p.flags?.includes('corresponding-author'))
  .sort((a, b) => b.year * 12 + (b.month ?? 0) - (a.year * 12 + (a.month ?? 0)))[0];

const primaryEmail = profile.emails.find((e) => e.primary) ?? profile.emails[0];
---

<section class="relative overflow-hidden">
  <div
    class="absolute inset-0 -z-10 opacity-40 pointer-events-none"
    aria-hidden="true"
    style="background:
      radial-gradient(700px 280px at 14% 0%, color-mix(in oklch, var(--accent) 18%, transparent), transparent 60%),
      radial-gradient(560px 240px at 92% 14%, color-mix(in oklch, var(--accent) 10%, transparent), transparent 60%);"
  >
  </div>

  <div class="container-page pt-20 pb-12 md:pt-24 md:pb-16">
    <div class="grid lg:grid-cols-[1fr_auto] gap-8 lg:gap-10 items-start">
      <div>
        <p class="text-xs font-mono uppercase tracking-[0.22em] text-[var(--accent)]">
          {profile.tagline[locale]}
        </p>

        <h1
          class="mt-4 font-serif text-3xl md:text-5xl font-semibold tracking-tight leading-[1.1]"
        >
          {profile.name[locale]}
        </h1>
        <p class="mt-2 text-sm text-muted">{profile.reading[locale]}</p>

        <dl class="mt-8 grid gap-x-8 gap-y-2 sm:grid-cols-[auto_1fr] max-w-3xl text-sm">
          <dt class="text-muted">{s.labels.affiliation}</dt>
          <dd>{profile.affiliation[locale]}</dd>
          <dt class="text-muted">{s.labels.position}</dt>
          <dd>{profile.position[locale]}</dd>
          <dt class="text-muted">{s.labels.degree}</dt>
          <dd>{profile.degree[locale]}</dd>
          <dt class="text-muted">Email</dt>
          <dd>
            <a
              class="underline-offset-4 hover:underline"
              href={`mailto:${primaryEmail.address}`}>{primaryEmail.address}</a
            >
          </dd>
          <dt class="text-muted">ORCID</dt>
          <dd>
            <a
              class="underline-offset-4 hover:underline font-mono tabular-nums"
              href={`https://orcid.org/${profile.orcid}`}
              target="_blank"
              rel="noreferrer">{profile.orcid}<span class="sr-only">{locale === 'ja' ? '（新しいタブで開きます）' : ' (opens in a new tab)'}</span></a
            >
          </dd>
        </dl>
      </div>

      {
        profile.portrait && (
          <Portrait
            locale={locale}
            class="hero-portrait shrink-0 w-32 sm:w-40 lg:w-48 aspect-square rounded-full overflow-hidden border hairline shadow-sm justify-self-start lg:justify-self-end"
          />
        )
      }
    </div>

    {
      recent && (
        <p class="mt-8 max-w-3xl text-sm text-muted">
          <span class="font-mono uppercase tracking-wider text-[var(--accent)] mr-2">
            {locale === 'ja' ? '最新' : 'Recent'}
          </span>
          <span class="italic">{recent.title}</span>
          <span class="text-muted">
            {' '}— {locale === 'en' && recent.venueEn ? recent.venueEn : recent.venue}, {recent.year}
          </span>
        </p>
      )
    }

    <div class="mt-8 flex flex-wrap gap-2">
      <a
        href="#publications"
        class="inline-flex items-center gap-2 px-4 py-2 rounded-md bg-[var(--accent)] text-[var(--accent-contrast)] text-sm font-medium hover:opacity-90 transition-opacity"
      >
        {s.nav.publications}
        <span aria-hidden="true">→</span>
      </a>
      <a
        href={locale === 'ja' ? '/cv' : '/en/cv'}
        class="inline-flex items-center gap-2 px-4 py-2 rounded-md border hairline text-sm font-medium hover:bg-[var(--accent-soft)] transition-colors"
      >
        {locale === 'ja' ? '履歴書 (CV)' : 'Curriculum Vitae'}
      </a>
      <a
        href="#contact"
        class="inline-flex items-center gap-2 px-4 py-2 rounded-md border hairline text-sm font-medium hover:bg-[var(--accent-soft)] transition-colors"
      >
        {s.nav.contact}
      </a>
      {
        profile.links.map((l) => (
          <a
            href={l.href}
            target="_blank"
            rel="noreferrer"
            class="inline-flex items-center gap-2 px-4 py-2 rounded-md border hairline text-sm hover:bg-[var(--accent-soft)] transition-colors"
          >
            {l.label[locale]}
            <span aria-hidden="true">↗</span>
            <span class="sr-only">{locale === 'ja' ? '（新しいタブで開きます）' : '(opens in a new tab)'}</span>
          </a>
        ))
      }
    </div>
  </div>
</section>

<style>
  .hero-portrait img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
</style>

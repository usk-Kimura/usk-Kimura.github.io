---
import type { Locale } from '~/data/types';
import { profile } from '~/data';
import { buildRecent } from '~/data/recent';
import { formatYearMonth, isoYearMonth } from '~/i18n/format';
import { t } from '~/i18n/ui';
import Portrait from './Portrait.astro';

type Props = { locale: Locale };
const { locale } = Astro.props;
const s = t(locale);

const recents = buildRecent(locale, 4);
const primaryEmail = profile.emails.find((e) => e.primary) ?? profile.emails[0];
const opp = profile.openToOpportunities;
---

<section class="relative overflow-hidden">
  <div
    class="absolute inset-0 -z-10 opacity-40 pointer-events-none"
    aria-hidden="true"
    style="background:
      radial-gradient(700px 280px at 14% 0%, color-mix(in oklch, var(--accent) 18%, transparent), transparent 60%),
      radial-gradient(560px 240px at 92% 14%, color-mix(in oklch, var(--accent) 10%, transparent), transparent 60%);"
  >
  </div>

  <div class="container-page pt-12 pb-12 md:pt-16 md:pb-16">
    {
      opp && (
        <a
          href="#contact"
          class="group inline-flex flex-wrap items-center gap-x-3 gap-y-1 px-4 py-2 mb-10 md:mb-12 rounded-full border-2 border-[var(--accent)] bg-[var(--accent-soft)] text-sm transition-all hover:shadow-md hover:-translate-y-0.5"
        >
          <span class="inline-flex items-center gap-2">
            <span class="relative flex w-2 h-2" aria-hidden="true">
              <span class="absolute inline-flex w-full h-full rounded-full bg-[var(--accent)] opacity-60 motion-safe:animate-ping" />
              <span class="relative inline-flex w-2 h-2 rounded-full bg-[var(--accent)]" />
            </span>
            <span class="font-mono uppercase tracking-[0.16em] text-[11px] text-[var(--accent)] font-semibold">
              {locale === 'ja' ? '次のポストを探しています' : 'Looking for a position'}
            </span>
          </span>
          <span class="text-[var(--fg)]">
            <strong class="font-semibold">{opp.startFrom[locale]}</strong>
            {locale === 'ja' ? '、' : ' — '}{opp.detail[locale]}
          </span>
          <span aria-hidden="true" class="text-muted group-hover:text-[var(--accent)] transition-colors">→</span>
        </a>
      )
    }
    <div class="grid lg:grid-cols-[1fr_auto] gap-8 lg:gap-10 items-start">
      <div>
        <p class="text-xs font-mono uppercase tracking-[0.22em] text-[var(--accent)]">
          {profile.tagline[locale]}
        </p>

        <h1
          class="mt-4 font-serif text-3xl md:text-5xl font-semibold tracking-tight leading-[1.1]"
        >
          {profile.name[locale]}
        </h1>
        <p class="mt-2 text-sm text-muted">{profile.reading[locale]}</p>

        <dl class="mt-8 grid gap-x-8 gap-y-2 sm:grid-cols-[auto_1fr] max-w-3xl text-sm">
          <dt class="text-muted">{s.labels.affiliation}</dt>
          <dd>{profile.affiliation[locale]}</dd>
          <dt class="text-muted">{s.labels.position}</dt>
          <dd>{profile.position[locale]}</dd>
          <dt class="text-muted">{s.labels.degree}</dt>
          <dd>{profile.degree[locale]}</dd>
          <dt class="text-muted">Email</dt>
          <dd>
            <a
              class="underline-offset-4 hover:underline"
              href={`mailto:${primaryEmail.address}`}>{primaryEmail.address}</a
            >
          </dd>
          <dt class="text-muted">ORCID</dt>
          <dd>
            <a
              class="underline-offset-4 hover:underline font-mono tabular-nums"
              href={`https://orcid.org/${profile.orcid}`}
              target="_blank"
              rel="noreferrer">{profile.orcid}<span class="sr-only">{locale === 'ja' ? '（新しいタブで開きます）' : ' (opens in a new tab)'}</span></a
            >
          </dd>
        </dl>
      </div>

      {
        profile.portrait && (
          <Portrait
            locale={locale}
            class="hero-portrait shrink-0 w-32 sm:w-40 lg:w-48 aspect-square rounded-full overflow-hidden border hairline shadow-sm justify-self-start lg:justify-self-end"
          />
        )
      }
    </div>

    {
      recents.length > 0 && (
        <section class="mt-10 max-w-3xl" aria-labelledby="recent-heading">
          <h2
            id="recent-heading"
            class="text-xs font-mono uppercase tracking-[0.22em] text-[var(--accent)] mb-3"
          >
            {s.recent.heading}
          </h2>
          <ul class="divide-y hairline border-y hairline">
            {recents.map((item) => {
              const dateLabel = formatYearMonth(item.date.slice(0, 7), locale);
              const dateAttr = isoYearMonth(item.date.slice(0, 7));
              const content = (
                <div class="flex flex-col sm:flex-row sm:items-baseline gap-1 sm:gap-4 py-3">
                  <div class="sm:w-36 shrink-0 flex items-baseline gap-3">
                    <time class="font-mono text-xs text-muted tabular-nums" datetime={dateAttr}>
                      {dateLabel}
                    </time>
                    <span class="text-[10px] font-mono uppercase tracking-wider text-[var(--accent)]">
                      {s.newsKinds[item.kind]}
                    </span>
                  </div>
                  <div class="min-w-0 flex-1">
                    <p class="text-sm leading-snug">{item.title}</p>
                    {item.detail && (
                      <p class="mt-0.5 text-xs text-muted truncate">{item.detail}</p>
                    )}
                  </div>
                </div>
              );
              return (
                <li>
                  {item.href ? (
                    <a
                      href={item.href}
                      class="block hover:bg-[var(--accent-soft)] -mx-2 px-2 rounded transition-colors"
                    >
                      {content}
                    </a>
                  ) : (
                    content
                  )}
                </li>
              );
            })}
          </ul>
        </section>
      )
    }

    <div class="mt-8 flex flex-wrap gap-2">
      <a
        href="#publications"
        class="inline-flex items-center gap-2 px-4 py-2 rounded-md bg-[var(--accent)] text-[var(--accent-contrast)] text-sm font-medium hover:opacity-90 transition-opacity"
      >
        {s.nav.publications}
        <span aria-hidden="true">→</span>
      </a>
      <a
        href={locale === 'ja' ? '/cv' : '/en/cv'}
        class="inline-flex items-center gap-2 px-4 py-2 rounded-md border hairline text-sm font-medium hover:bg-[var(--accent-soft)] transition-colors"
      >
        {locale === 'ja' ? '履歴書 (CV)' : 'Curriculum Vitae'}
      </a>
      <a
        href="#contact"
        class="inline-flex items-center gap-2 px-4 py-2 rounded-md border hairline text-sm font-medium hover:bg-[var(--accent-soft)] transition-colors"
      >
        {s.nav.contact}
      </a>
      {
        profile.links.map((l) => (
          <a
            href={l.href}
            target="_blank"
            rel="noreferrer"
            class="inline-flex items-center gap-2 px-4 py-2 rounded-md border hairline text-sm hover:bg-[var(--accent-soft)] transition-colors"
          >
            {l.label[locale]}
            <span aria-hidden="true">↗</span>
            <span class="sr-only">{locale === 'ja' ? '（新しいタブで開きます）' : '(opens in a new tab)'}</span>
          </a>
        ))
      }
    </div>
  </div>
</section>

<style>
  .hero-portrait img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
</style>
